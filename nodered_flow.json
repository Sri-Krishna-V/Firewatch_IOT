  {
    "id": "n_fn_alert_check",
    "type": "function",
    "z": "tab1",
    "name": "Combine Alert Status",
    "func": "var gasAlert = flow.get('gas_alert') || false;\nvar tempAlert = flow.get('temp_alert') || false;\nvar motionAlert = flow.get('motion_alert') || false;\nvar gasStatus = flow.get('gas_status') || 'SAFE';\nvar tempStatus = flow.get('temp_status') || 'NORMAL';\nvar motionStatus = flow.get('motion_status') || 'AREA CLEAR';\n\nvar anyAlert = gasAlert || tempAlert || motionAlert;\nvar messages = [];\nif (gasAlert) messages.push('[GAS] ' + gasStatus);\nif (tempAlert) messages.push('[TEMP] ' + tempStatus);\nif (motionAlert) messages.push('[MOTION] ' + motionStatus);\n\nvar alertText = anyAlert\n    ? '⚠ ALERT: ' + messages.join(' | ')\n    : '✔ All systems NORMAL';\n\nmsg.payload = alertText;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 560,
    "y": 560,
    "wires": [["n_text_alerts", "n_notification_alert"]]
  },
