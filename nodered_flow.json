  {
    "id": "n_mqtt_motion",
    "type": "mqtt in",
    "z": "tab1",
    "name": "fire/motion",
    "topic": "fire/motion",
    "qos": "1",
    "datatype": "auto",
    "broker": "hivemq_broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "x": 100,
