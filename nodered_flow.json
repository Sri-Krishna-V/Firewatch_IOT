  {
    "id": "n_mqtt_temp",
    "type": "mqtt in",
    "z": "tab1",
    "name": "fire/temp",
    "topic": "fire/temp",
    "qos": "1",
    "datatype": "auto",
    "broker": "hivemq_broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "x": 100,
    "y": 260,
    "wires": [["n_fn_temp"]]
  },
  {
    "id": "n_fn_temp",
    "type": "function",
    "z": "tab1",
    "name": "Process Temperature",
    "func": "var payload = msg.payload;\nvar temp = 25;\nvar status = 'NORMAL';\nvar alert = false;\n\nif (typeof payload === 'number') {\n    temp = payload;\n} else if (typeof payload === 'string') {\n    temp = parseFloat(payload) || 25;\n} else if (typeof payload === 'object' && payload !== null) {\n    temp = payload.temperature || payload.temp || payload.value || 25;\n}\n\n// Fire safety temperature thresholds\nif (temp >= 60) {\n    status = 'FIRE ALERT! CRITICAL';\n    alert = true;\n} else if (temp >= 45) {\n    status = 'HIGH TEMP WARNING';\n    alert = true;\n} else if (temp >= 35) {\n    status = 'ELEVATED TEMP';\n} else {\n    status = 'NORMAL';\n}\n\nflow.set('temp_value', temp);\nflow.set('temp_status', status);\nflow.set('temp_alert', alert);\n\nreturn [{ payload: temp }, { payload: status }, { payload: alert }, msg];",
    "outputs": 4,
    "noerr": 0,
    "x": 300,
    "y": 260,
    "wires": [
      ["n_gauge_temp"],
      ["n_text_temp"],
      ["n_led_temp"],
      ["n_fn_alert_check"]
    ]
  },
