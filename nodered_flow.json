  {
    "id": "n_mqtt_gas",
    "type": "mqtt in",
    "z": "tab1",
    "name": "fire/gas",
    "topic": "fire/gas",
    "qos": "1",
    "datatype": "auto",
    "broker": "hivemq_broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "x": 100,
    "y": 100,
    "wires": [["n_fn_gas"]]
  },
  {
    "id": "n_fn_gas",
    "type": "function",
    "z": "tab1",
    "name": "Process Gas",
    "func": "var payload = msg.payload;\nvar value = 0;\nvar status = 'SAFE';\nvar leakDetected = false;\n\n// Parse payload - supports number, string, or JSON object\nif (typeof payload === 'number') {\n    value = payload;\n} else if (typeof payload === 'string') {\n    var lower = payload.toLowerCase().trim();\n    if (lower === 'leak' || lower === 'alert' || lower === '1' || lower === 'true') {\n        value = 850; leakDetected = true;\n    } else if (lower === 'safe' || lower === '0' || lower === 'false') {\n        value = 80;\n    } else {\n        value = parseFloat(payload) || 0;\n    }\n} else if (typeof payload === 'object' && payload !== null) {\n    value = payload.value || payload.ppm || payload.adc || 0;\n}\n\n// Threshold logic (ADC-based: 0-1023)\nif (value > 400 || leakDetected) {\n    status = 'GAS LEAK DETECTED!';\n    leakDetected = true;\n} else if (value > 200) {\n    status = 'WARNING: Elevated Gas';\n} else {\n    status = 'SAFE';\n}\n\nflow.set('gas_value', value);\nflow.set('gas_status', status);\nflow.set('gas_alert', leakDetected);\n\n// Output 1: gauge value\n// Output 2: status text\n// Output 3: LED bool\n// Output 4: alert check\nreturn [{ payload: value }, { payload: status }, { payload: leakDetected }, msg];",
    "outputs": 4,
    "noerr": 0,
    "x": 300,
    "y": 100,
    "wires": [
      ["n_gauge_gas"],
      ["n_text_gas"],
      ["n_led_gas"],
      ["n_fn_alert_check"]
    ]
  },
