  {
    "id": "n_fn_motion",
    "type": "function",
    "z": "tab1",
    "name": "Process Motion",
    "func": "var payload = msg.payload;\nvar detected = false;\nvar status = 'NO MOTION';\n\nif (typeof payload === 'boolean') {\n    detected = payload;\n} else if (typeof payload === 'number') {\n    detected = payload === 1;\n} else if (typeof payload === 'string') {\n    var lower = payload.toLowerCase().trim();\n    detected = (lower === '1' || lower === 'true' || lower === 'motion' || lower === 'detected' || lower === 'yes');\n} else if (typeof payload === 'object' && payload !== null) {\n    detected = !!(payload.motion || payload.detected || payload.value);\n}\n\nstatus = detected ? 'MOTION DETECTED!' : 'AREA CLEAR';\nvar count = (flow.get('motion_count') || 0);\nif (detected) count++;\nflow.set('motion_count', count);\nflow.set('motion_status', status);\nflow.set('motion_alert', detected);\n\nreturn [{ payload: count }, { payload: status }, { payload: detected }, msg];",
    "outputs": 4,
    "noerr": 0,
    "x": 300,
    "y": 420,
    "wires": [
      ["n_chart_motion"],
      ["n_text_motion"],
      ["n_led_motion"],
      ["n_fn_alert_check"]
    ]
  },
